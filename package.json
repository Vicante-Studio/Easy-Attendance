{
    "name": "easycounter",
    "version": "1.0.0",
    "private": true,
    "description": "Church attendance counter — LAN desktop app",
    "main": "electron/main.js",
    "workspaces": [
        "app/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently -n SERVER,CLIENT,ELECTRON -c green,blue,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
        "dev:server": "cd app/server && npm run dev",
        "dev:client": "cd app/client && npm run dev",
        "dev:electron": "npm run build:electron && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
        "build:electron": "esbuild electron/main.ts --bundle --platform=node --target=node22 --external:electron --format=cjs --outfile=electron/main.js",
        "build:client": "cd app/client && npm run build",
        "build:server": "esbuild app/server/server.ts --bundle --platform=node --target=node22 --format=cjs --external:@prisma/client --external:.prisma --external:better-sqlite3 --outfile=app/server/dist/server.cjs",
        "build:all": "cd app/server && npx prisma generate && cd ../.. && npm run build:client && npm run build:server && npm run build:electron",
        "package": "npm run build:all && node -e \"require('fs').existsSync('app/server/dist/server.cjs') || process.exit(1)\" && cross-env NODE_ENV=production electron-builder"
    },
    "build": {
        "appId": "com.easycounter.app",
        "productName": "EasyCounter",
        "asar": false,
        "directories": {
            "output": "release"
        },
        "files": [
            "electron/**/*",
            "app/server/dist/**/*",
            "app/client/dist/**/*",
            "app/server/prisma/**/*",
            "node_modules/@prisma/**/*",
            "node_modules/.prisma/**/*",
            "package.json"
        ],
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg"
        }
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^42.0.1",
        "electron-builder": "^26.8.1",
        "electron-rebuild": "^1.4.0",
        "esbuild": "^0.28.0",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "wait-on": "^9.0.5"
    },
    "dependencies": {
        "axios": "^1.15.0",
        "electron-log": "^5.4.4"
    }
}
