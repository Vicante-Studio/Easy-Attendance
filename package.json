{
    "name": "easycounter",
    "version": "1.0.0",
    "private": true,
    "description": "Church attendance counter — LAN desktop app",
    "main": "electron/main.js",
    "workspaces": [
        "app/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently -n SERVER,CLIENT,ELECTRON -c green,blue,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
        "dev:server": "cd app/server && npm run dev",
        "dev:client": "cd app/client && npm run dev",
        "dev:electron": "npm run build:electron && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
        "build:electron": "esbuild electron/main.ts --bundle --platform=node --target=node22 --external:electron --format=cjs --outfile=electron/main.js",
        "build:client": "cd app/client && npm run build",
        "build:server": "esbuild app/server/server.ts --bundle --platform=node --target=node22 --external:better-sqlite3 --format=cjs --outfile=app/server/dist/server.cjs",
        "build:all": "npm run build:client && npm run build:server && npm run build:electron",
        "package": "npm run build:all && electron-builder",
        "postinstall": "electron-rebuild"
    },
    "build": {
        "appId": "com.easycounter.app",
        "productName": "EasyCounter",
        "directories": {
            "output": "release"
        },
        "asarUnpack": [
            "**/*.node"
        ],
        "files": [
            "electron/main.js",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "app/server/dist",
                "to": "app/server/dist"
            },
            {
                "from": "app/data",
                "to": "app/data"
            },
            {
                "from": "node_modules/better-sqlite3",
                "to": "app/node_modules/better-sqlite3"
            },
            {
                "from": "node_modules/bindings",
                "to": "app/node_modules/bindings"
            },
            {
                "from": "node_modules/file-uri-to-path",
                "to": "app/node_modules/file-uri-to-path"
            }
        ],
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg"
        }
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^42.0.1",
        "electron-builder": "^26.8.1",
        "electron-rebuild": "^3.2.9",
        "esbuild": "^0.28.0",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "wait-on": "^9.0.5"
    },
    "dependencies": {
        "axios": "^1.15.0",
        "electron-log": "^5.4.4"
    }
}
